# Example environment variables for Chimera Wallet PWA
# Copy this file to .env and modify as needed
# For production/staging environments, use .env.production or .env.staging

CI=false
GENERATE_SOURCEMAP=false

# Ark Network
# VITE_ARK_SERVER=https://arkade.computer
# VITE_BOLTZ_URL=https://api.ark.boltz.exchange

# Chimera API
# VITE_CHIMERA_API=https://api.chimerawallet.com/v1

# KYC/IDFlow
# VITE_KYC_API_URL=https://api.idflow.ch
# VITE_KYC_WEBVIEW_URL=https://demo.idflow.ch/

# Plausible Analytics
# VITE_PLAUSIBLE_DOMAIN=app.chimerawallet.com

# ChatWoot
# VITE_CHATWOOT_WEBSITE_TOKEN=your-token
# VITE_CHATWOOT_BASE_URL=https://app.chatwoot.com

# Third-party integrations
# VITE_LENDASAT_IFRAME_URL=https://iframe.lendasat.com
# VITE_LENDASWAP_IFRAME_URL=https://iframe.lendaswap.com

# App URL overrides (optional)
# These override the default URLs configured in src/lib/appConfig.ts
# VITE_GIFT_CARDS_URL=
# VITE_CARD_RESERVATION_URL=
# VITE_STATEMENT_URL=
# VITE_REFERRAL_URL=

# Other optional settings
# VITE_SENTRY_DSN=
# VITE_MAX_PERCENTAGE=10
# VITE_PSA_MESSAGE=
